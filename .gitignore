# =============================================================================
# .gitignore
# =============================================================================

# --- Dependencies ---
node_modules/
.pnp
.pnp.js

# --- Environment variables ---
.env
.env*.local
.env.development
.env.production
# (keep .env.example tracked)
!.env.example

# --- Next.js ---
.next/
out/
build/
dist/

# --- Production / misc ---
*.tsbuildinfo
next-env.d.ts

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# --- Testing ---
coverage/
.nyc_output/

# --- Caches ---
.cache/
.eslintcache
.turbo/

# --- OS files ---
.DS_Store
Thumbs.db

# --- Editor / IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# --- Vercel ---
.vercel